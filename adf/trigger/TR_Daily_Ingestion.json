{
  "name": "TR_Daily_Ingestion",
  "properties": {
    "description": "Daily schedule trigger for master ingestion pipeline.",
    "annotations": ["phase2", "schedule"],
    "type": "ScheduleTrigger",
    "typeProperties": {
      "recurrence": {
        "frequency": "Day",
        "interval": 1,
        "startTime": "2026-01-01T02:00:00Z",
        "timeZone": "UTC"
      }
    },
    "pipelines": [
      {
        "pipelineReference": {
          "type": "PipelineReference",
          "referenceName": "PL_Master_Ingestion"
        },
        "parameters": {
          "storageAccountUrl": "@trigger().outputs.storageAccountUrl",
          "filesystem": "raw",
          "postgresHost": "@trigger().outputs.postgresHost",
          "postgresPort": 55432,
          "postgresDatabase": "retail_db",
          "postgresUser": "retail_user"
        }
      }
    ]
  }
}
