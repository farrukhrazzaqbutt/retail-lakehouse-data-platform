# =============================================================================
# Retail Lakehouse Data Platform — Environment Variables
# Copy this file to `.env` and fill in values before running pipelines.
# Never commit `.env` to version control.
# =============================================================================

# --- PostgreSQL (Phase 1: source transactional database) ---
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=55432
POSTGRES_DB=retail_db
POSTGRES_USER=retail_user
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_SCHEMA=retail

# --- Data generation ---
DATA_GENERATION_SEED=42
DATA_OUTPUT_DIR=./data/generated
DATA_SAMPLE_OUTPUT_DIR=./data/samples

# Customer / product / order volume controls
NUM_CUSTOMERS=5000
NUM_PRODUCTS=500
NUM_ORDERS=25000
ORDER_START_DATE=2023-01-01
ORDER_END_DATE=2025-06-30

# --- Azure Data Factory (Phase 2+) ---
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_DATA_FACTORY_NAME=
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=raw
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Databricks (Phase 3+) ---
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_CLUSTER_ID=
DATABRICKS_CATALOG=retail_lakehouse
DATABRICKS_SCHEMA=default

# --- Snowflake (Phase 4+) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=RETAIL_DW
SNOWFLAKE_SCHEMA=RAW

# --- dbt (Phase 4+) ---
DBT_PROFILES_DIR=./dbt/profiles
DBT_TARGET=dev

# --- Airflow (Phase 5+) ---
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://retail_user:change_me_secure_password@localhost:5432/airflow_db

# --- Logging ---
LOG_LEVEL=INFO
